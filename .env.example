# Scanner Authentication
SCANNER_SECRET=your_very_strong_random_secret_here_minimum_32_chars

# Firebase Configuration (choose ONE method)

# Method 1: Base64 encoded service account JSON (recommended)
FIREBASE_SERVICE_ACCOUNT_JSON=<base64_of_serviceAccount.json>

# Method 2: Individual Firebase credentials
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Scanner Identification (optional but recommended)
SCANNER_OPERATOR=scanner-device-1

# Production Settings
NODE_ENV=production
